# Copy to .env on the EC2 host, next to docker-compose.yml, and fill in real values.
# This file is consumed by docker-compose.yml — do NOT commit the real .env.

# Postgres container credentials (used to build DATABASE_URL internally — no need to set DATABASE_URL yourself)
POSTGRES_USER=pfms
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pfms

# Session cookie signing secret — generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# First-run admin account
ADMIN_USERNAME=Pikajuz
ADMIN_PASSWORD=change-me

# Set true only on the very first deploy if you want demo data seeded automatically, then set back to false
SEED_ON_START=false

# Optional SMTP for email notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WC Finance <noreply@example.com>

# --- If you switch to RDS later instead of the bundled postgres container ---
# 1. Remove/comment the `db` service in docker-compose.yml and the `depends_on` block under `app`
# 2. Replace the app's DATABASE_URL with your RDS endpoint directly, e.g.:
# DATABASE_URL_OVERRIDE=postgresql://USER:PASS@your-rds-endpoint.rds.amazonaws.com:5432/pfms?sslmode=require
