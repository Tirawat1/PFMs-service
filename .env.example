POSTGRES_USER=pfms
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pfms

# Session cookie signing secret — generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# First-run admin account
ADMIN_USERNAME=Pikajuz
ADMIN_PASSWORD=change-me

# Set true only on the very first deploy if you want demo data seeded automatically, then set back to false
SEED_ON_START=false

# Optional SMTP for email notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WC Finance <noreply@example.com>