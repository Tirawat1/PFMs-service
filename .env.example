POSTGRES_USER=pfms
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pfms

# Prisma reads this directly — must match POSTGRES_USER/PASSWORD/DB above.
# localhost:5432 because the app runs on the host and the db container
# only publishes to 127.0.0.1:5432 (see docker-compose.yml).
DATABASE_URL=postgresql://pfms:change-me-strong-password@localhost:5432/pfms

# Session cookie signing secret — generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# First-run admin account
ADMIN_USERNAME=Pikajuz
ADMIN_PASSWORD=change-me

# Set true only on the very first deploy if you want demo data seeded automatically, then set back to false
SEED_ON_START=false

# Optional SMTP for email notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WC Finance <noreply@example.com>

# Google Sheets backup mirror (see backup-plan-google-sheets.md) — all optional, sync no-ops if unset
# OAuth2 "Web application" client — Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# One-time refresh token from OAuth 2.0 Playground (scope: https://www.googleapis.com/auth/spreadsheets)
GOOGLE_REFRESH_TOKEN=
# Spreadsheet ID from the sheet's URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_BACKUP_ID=
# Shared secret the cron job sends as `x-cron-secret` header to trigger the backup route
CRON_SECRET=