# Postgres connection string (Neon / Vercel Postgres / Supabase / Railway)
DATABASE_URL="postgresql://user:password@host:5432/pfms?sslmode=require"

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# First-run admin account (created automatically on first login attempt when the DB is empty)
ADMIN_USERNAME="Pikajuz"
ADMIN_PASSWORD="WCFin"

# Optional SMTP for email notifications (leave blank to disable email sending)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="WC Finance <noreply@example.com>"
